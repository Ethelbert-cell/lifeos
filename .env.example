# LifeOS Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Your app's base URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Atlas → Your cluster → Connect → Drivers → Node.js
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lifeos
MONGODB_URI=

# ─── Public App URL ───────────────────────────────────────────────────────────
# Used for Open Graph meta tags and absolute URL generation
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
